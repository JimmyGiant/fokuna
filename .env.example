# Data driver: `memory` (default local) or `neon`
FOKUNA_DATA_DRIVER="memory"

# Neon PostgreSQL (EU region recommended) — required when FOKUNA_DATA_DRIVER=neon
DATABASE_URL="postgresql://user:password@host.neon.tech/fokuna?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (optional locally — verification/reset emails are logged when unset)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Fokuna <auth@example.com>"

# Observability (optional)
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Stripe (Phase 5)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Calendar OAuth (Phase 5)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# AccuWeather (Phase 5)
ACCUWEATHER_API_KEY=""

# Credential encryption for integrations (Phase 5)
INTEGRATION_ENCRYPTION_KEY=""
