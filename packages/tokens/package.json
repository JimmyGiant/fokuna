{
  "name": "@fokuna/tokens",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/theme.css",
    "./typography.css": "./src/typography.css",
    "./tailwind.css": "./src/tailwind.css",
    "./tokens.json": "./src/tokens.json"
  },
  "scripts": {
    "build": "node scripts/build-tokens.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@fokuna/config": "workspace:*",
    "prettier": "3.9.5",
    "typescript": "5.9.3"
  }
}
